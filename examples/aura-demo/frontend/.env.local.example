# Server-only backend origin. Read by next.config.js rewrites + src/lib/api.ts (server-side).
# Dev: leave unset → defaults to http://localhost:8000.
# Prod (Vercel): set API_URL=https://your-backend.example.com (NOT public; never shipped to client).
# API_URL=

# Optional. When the backend has ADMIN_SECRET set, paste the same value here
# so the dev /admin/reset call can send it. This is injected at request time
# via sessionStorage; it is never baked into the build.
# NEXT_PUBLIC_ADMIN_SECRET_HINT=demo-secret
