# Authentication — REQUIRED in production.
# Boot will fail loudly if these are empty when AUTH_ENFORCE=1 (the default).
# Use AUTH_ENFORCE=0 only for local development; never in production.
AUTH_SECRET=
AUTH_ADMIN_PASSWORD=
AUTH_ENFORCE=1

# Optional. Admin username for the bootstrap account created on first boot.
AUTH_ADMIN_USERNAME=admin

# Optional. When set, destructive admin endpoints (e.g. /admin/reset) require
# the X-Admin-Secret header to match this value. Leave unset for local demos.
ADMIN_SECRET=

# Required for Claude-powered chat/voice. Empty means deterministic MockLLM only.
# Set a valid key for production; the app will warn but not fail boot if empty.
ANTHROPIC_API_KEY=

# Optional. Comma-separated list of allowed frontend origins for CORS.
# Defaults to "*" (permissive) which is fine for local dev but should be
# restricted in production, e.g. "https://aura-demo.example.com".
CORS_ALLOWED_ORIGINS=

# Optional. Number of seconds between auto market ticks when auto-run is enabled.
# AUTO_INTERVAL_SEC=5

# Optional. Set to truthy to start the market auto-run loop on startup.
# MARKET_AUTO_RUN=false

# Optional. Set to 1/true to enable Claude-assisted variable ranking in
# /hermes/generate expanded search. When unset or false the generator is
# fully deterministic and offline-safe.
# HERMES_GENERATOR_LLM=false

# --- Conversational Assurance voice (optional) ---
# If all three LiveKit variables are set, the frontend can join a real-time
# voice room. The server-side agent also needs DEEPGRAM_API_KEY (STT) and
# OPENAI_API_KEY (TTS) if you run agents/livekit_assistant.py.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ASSURE_API_BASE=http://127.0.0.1:8000
